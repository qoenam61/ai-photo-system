# 환경변수 placeholder — 실제 값은 `.env.gpg`에 암호화 저장
# 복호화: gpg --decrypt .env.gpg > .env (gpg-agent 자동)
# 사용 시: docker compose --env-file .env up

# ─────────────────────────────────────────────
# Database (Postgres) — 사진 schema
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_postgres
POSTGRES_PHOTO_SCHEMA=photo
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=<encrypted>

# ─────────────────────────────────────────────
# Redis (사진 시스템 별도 prefix)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PHOTO_PREFIX=photo:

# ─────────────────────────────────────────────
# Immich
# ─────────────────────────────────────────────
IMMICH_URL=http://localhost:2283
IMMICH_API_KEY=<encrypted>
IMMICH_ADMIN_PASSWORD=<encrypted>

# ─────────────────────────────────────────────
# Ollama (로컬 LLM)
# ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=qwen2.5vl:7b-q4_K_M
OLLAMA_WHISPER_MODEL=whisper:small
OLLAMA_KEEP_ALIVE=30m

# ─────────────────────────────────────────────
# Telegram (알림)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<encrypted>
TELEGRAM_CHAT_ID=<encrypted>

# ─────────────────────────────────────────────
# Tailscale (외부 접근)
# ─────────────────────────────────────────────
TAILSCALE_AUTHKEY=<encrypted>
TAILSCALE_HOSTNAME=photo-mac

# ─────────────────────────────────────────────
# Storage Paths
# ─────────────────────────────────────────────
# Phase 0~5: SSD 임시 vault
PHOTO_VAULT_PATH=/Users/Shared/PhotoVault
# Phase 6~: HDD
HDD_PATH=/Volumes/PhotoHDD/immich-media

# ─────────────────────────────────────────────
# 사용자별 인증 (iOS Shortcut / MacroDroid)
# ─────────────────────────────────────────────
JW_SON_BEARER_TOKEN=<encrypted>
EUNJU_BEARER_TOKEN=<encrypted>

# ─────────────────────────────────────────────
# Galaxy Cloud 단방향 푸시 (eunju)
# ─────────────────────────────────────────────
GALAXY_BACKUP_HOME_WIFI_SSID=<your_wifi_ssid>

# ─────────────────────────────────────────────
# Observability (Phase 1+)
# ─────────────────────────────────────────────
LOKI_URL=http://localhost:3100
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=<encrypted>

# ─────────────────────────────────────────────
# 로그 레벨
# ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
