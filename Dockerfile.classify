FROM python:3.12-slim

# OpenCV + image utils + ffprobe
RUN apt-get update && apt-get install -y --no-install-recommends \
      libgl1 libglib2.0-0 \
      ffmpeg \
      curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml poetry.lock* ./

RUN pip install --no-cache-dir \
      'fastapi>=0.115' \
      'uvicorn[standard]>=0.32' \
      'httpx>=0.27' \
      'pydantic>=2.9' \
      'psycopg[binary]>=3.2' \
      'opencv-python-headless>=4.10' \
      'pillow>=11.0' \
      'pillow-heif>=0.18' \
      'numpy>=2.0' \
      'python-dotenv>=1.0'

COPY core /app/core

ENV PYTHONPATH=/app \
    LITELLM_BASE_URL=http://host.docker.internal:4000 \
    LITELLM_MASTER_KEY=local-litellm-key \
    OLLAMA_URL=http://host.docker.internal:11434/api/generate \
    PHOTO_DB_DSN="host=trading_postgres port=5432 dbname=trading_db user=trading_user password=RyIokQY7bV3y7SEsyFLu2Oa6" \
    STORAGE_PREFIX=/storage \
    STORAGE_PREFIX_FROM=/Volumes/Immich-Storage

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8000/health || exit 1

CMD ["uvicorn", "core.api.classify_server:app", "--host", "0.0.0.0", "--port", "8000"]
