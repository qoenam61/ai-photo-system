    <key>StandardOutPath</key>
    <string>/Users/jw-home/Work/photo_system/ai-photo-system/scripts/_inventory/cleanup_photos_mac.stdout</string>

    <key>StandardErrorPath</key>
    <string>/Users/jw-home/Work/photo_system/ai-photo-system/scripts/_inventory/cleanup_photos_mac.stderr</string>
</dict>
</plist>
