<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.photo.cleanup-mac</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/jw-home/Work/photo_system/ai-photo-system &amp;&amp; PYTHONPATH=. /Users/jw-home/.local/bin/poetry run python scripts/cleanup_photos_mac.py --grades "FOOD,MEMORY-,NORMAL,TRASH" --no-progressive --limit 1000 --min-age-days 0 &gt;&gt; scripts/_inventory/cleanup_photos_mac.log 2&gt;&amp;1</string>
    </array>

    <key>StartCalendarInterval</key>
